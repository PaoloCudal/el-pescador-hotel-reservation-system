@page "/BookNow"
@{
    Layout = "_Layout";
    ViewData["Title"] = "Booking – El Pescador Resort Hotel";
}

<link rel="stylesheet" href="css/BookNow.css"/>

<div class="summary-page-wrapper">

    <div class="booking-card" style="max-width: 600px; width: 100%;">
        <h4 class="booking-title" style="font-size:22px;">Booking Details</h4>

        <form id="bookingForm">
            <input type="hidden" id="roomTypeId" />
            <input type="hidden" id="venueId" />
            <input type="hidden" id="facilityId" />

            <div class="row mt-3">
                <div class="col-md-6">
                    <label class="booking-label">Check-In Date</label>
                    <input class="form-control" id="checkIn" type="date" required />
                </div>
                <div class="col-md-6">
                    <label class="booking-label">Check-Out Date</label>
                    <input class="form-control" id="checkOut" type="date" required />
                </div>
            </div>

            <div class="mt-3">
                <label class="booking-label">Special Requests (Optional)</label>
                <textarea class="form-control" id="specialRequest" rows="3"></textarea>
            </div>

            <div class="price-summary-box mt-3">
                <p class="price-amount mb-1" id="liveTotalCost">₱0</p>
                <p class="text-muted mb-0" id="livePriceDetails"></p>
            </div>

            <button type="submit" class="btn-book mt-4" id="submitBookingBtn">
              <span id="btnText">Submit Booking</span>
              <span id="btnSpinner" class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"> </span>
            </button>
        </form>
    </div>

<script src="js/BookNow.js"></script>
</div>