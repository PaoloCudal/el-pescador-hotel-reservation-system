@page 
@model HotelReservationWeb.Pages.AmenitiesModel
@{
    Layout = null;
    ViewData["Title"] = "Amenities – El Pescador Resort Hotel";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
<link rel="stylesheet" href="/css/Amenities.css" />
<link rel="stylesheet" href="/css/UserModal.css" />

<nav id="mainNav" class="navbar navbar-expand-lg">
    <div class="container">
        <a class="navbar-brand" asp-page="/HomeIndex">El Pescador</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div id="navMenu" class="collapse navbar-collapse justify-content-end align-items-center">
            <ul class="navbar-nav ms-auto align-items-center">
                <li class="nav-item"><a class="nav-link" href="/HomeIndex#home">Home</a></li>
                <li class="nav-item"><a class="nav-link" asp-page="/Rooms">Rooms</a></li>
                <li class="nav-item"><a class="nav-link" asp-page="/Amenities">Amenities</a></li>
                <li class="nav-item"><a class="nav-link" asp-page="/Venues">Venues</a></li>
                <li class="nav-item"><a class="nav-link" href="/HomeIndex#discover">Discover</a></li>
                <li class="nav-item"><a class="nav-link" href="/HomeIndex#about">About</a></li>
                <li class="nav-item"><a class="nav-link" href="/HomeIndex#contact">Contact</a></li>
            </ul>
            <div class="dropdown ms-3" id="profileDropdown">
                <button class="btn profile-circle" id="profileMenuBtn" type="button">
                    <i class="bi bi-person-fill fs-4"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end elegant-dropdown" aria-labelledby="profileMenuBtn">
                    <!-- Content will be injected by JS -->
                </ul>
            </div>
        </div>
    </div>
</nav>

<header class="amenities-hero">
    <div class="hero-inner">
        <h1>Our Amenities</h1>
        <p class="lead" style="color:rgba(255,255,255,0.92); margin-top:.6rem;">
            Simple, elegant, and designed to complement your stay. Click any amenity for details.
        </p>
    </div>
    <div class="weather-widget" style="position:absolute;top:20px;right:30px;color:white;opacity:0.95;font-size:1rem;z-index:3;">
        <span id="weatherContent"><i class="bi bi-cloud-sun"></i> Loading weather...</span>
    </div>
</header>

<main class="container-amenities">
    <div class="row g-4" id="amenitiesGrid"></div>
</main>

<div id="amenityModalsContainer"></div>



<!-- USER PROFILE MODAL -->
<div class="modal fade" id="userProfileModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header rounded-top-4">
                <h5 class="modal-title fw-bold">
                    <i class="bi bi-person-circle me-2"></i> My Account
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body">
                        <h6 class="fw-bold text-primary mb-3">Profile Information</h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <small class="text-muted">Full Name</small>
                                <div class="fw-semibold" id="profileFullName">—</div>
                            </div>
                            <div class="col-md-6">
                                <small class="text-muted">Email</small>
                                <div class="fw-semibold" id="profileEmail">—</div>
                            </div>
                            <div class="col-md-6">
                                <small class="text-muted">Join Date</small>
                                <div class="fw-semibold" id="profileJoinDate">—</div>
                            </div>
                            <div class="col-md-6">
                                <small class="text-muted">Favorites</small>
                                <div class="fw-semibold d-flex flex-column gap-1 mt-1">
                                    <span id="profileFavoriteRooms" class="profile-value">Favorite Rooms: 0</span>
                                    <span id="profileFavoriteVenues" class="profile-value">Favorite Venues: 0</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <h6 class="fw-bold text-primary mb-3">Bookings History</h6>
                <div id="activeBookingsList" class="vstack gap-3"></div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- SCRIPTS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>
<script src="/js/site.js"></script>
<script src="/js/Amenities.js"></script>


<script>
    document.addEventListener("DOMContentLoaded", () => {
        // Accessibility: card keyboard activation (amenity cards are dynamic, use delegation)
        document.getElementById("amenitiesGrid").addEventListener("keydown", (e) => {
            if (e.key !== "Enter" && e.key !== " ") return;
            const card = e.target.closest(".amenity-card");
            if (!card) return;
            e.preventDefault();
            const target = card.getAttribute("data-bs-target");
            if (target) new bootstrap.Modal(document.querySelector(target)).show();
        });

        // Parallax tilt effect on amenity cards (delegated — cards load dynamically)
        document.getElementById("amenitiesGrid").addEventListener("mousemove", (ev) => {
            const card = ev.target.closest(".amenity-card");
            if (!card) return;
            const img = card.querySelector(".amenity-image");
            if (!img) return;
            const r = card.getBoundingClientRect();
            const dx = (ev.clientX - (r.left + r.width / 2)) / r.width;
            const dy = (ev.clientY - (r.top + r.height / 2)) / r.height;
            img.style.transform = `scale(1.04) translate(${dx * 6}px, ${dy * 6}px)`;
        });

        document.getElementById("amenitiesGrid").addEventListener("mouseleave", (ev) => {
            const card = ev.target.closest(".amenity-card");
            if (!card) return;
            const img = card.querySelector(".amenity-image");
            if (img) img.style.transform = "";
        }, true);
    });
</script>