@page "/Pages"
@model HotelReservationWeb.Pages.PagesModel
@{
    Layout = null;
}

<!DOCTYPE html>
 <head>
     <meta charset="utf-8" />
     <meta name="viewport" content="width=device-width, initial-scale1.0" />
     <title>Privacy Policy | El Pescador Resort Hotel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body{
            font-family: 'Poppins', sans-serif;
            background: #f7f8fc;
            color: #333;
            margin: 0; padding: 0;
            overflow: hidden;
            position: relative;
        }
        .privacy-container{
            width: 70%;
            max-width: 700px;
            background: #fff;
            border-radius: 24px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
            padding: 2rem 2.5rem;
            box-sizing: border-box;
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            animation: fadeIn 0.5s ease-out;
        }
        .privacy-title{
            text-align: center;
            font-weight: 700;
            color: #f0ad4e;
            margin-bottom: 1.6rem;
            justify-content: center;
        }
        p, li{
            font-size: 1rem;
            line-height: 1.7;
            color: #444;         
        }
        ul{
            margin-left: 1.5rem;
        }
        .contact{
            font-size: 1rem;
            line-height: 1.7;
            color: #444;
            justify-content: center;
            text-align: center;
        }
        .contact-link{
            color: #1a73e8;
            font-weight: 600;
            text-decoration: none;
            cursor: pointer
        }
        .contact-link:hover {
            color: #1a73e8;
        }
        .footer-title {
            text-align: center;
            margin-top: 2rem;
            color: black;
            font-weight: 600;
        }
    </style>
 </head>
 <body>
     <div class="privacy-container">
         <h3 class="privacy-title">Privacy Policy</h3>
        <ul>
            <li>We comply with the Data Privacy Act of 2012 (RA 10173)</li>
            <li>All personal and sensitive information are securely stored and used only for authorized purposes</li>
            <li>We will not share your data with third parties without consent</li>
            <li>Any data breaches will be reported and handled according to law</li>
        </ul>
        <p class="contact">
            For further inquiries, please
            <a href="/HomeIndex#contact" class="contact-link">contact our support team</a>
        </p>

        <div class="footer-title">El Pescador Resort & Hotel</div>
     </div>
 </body>