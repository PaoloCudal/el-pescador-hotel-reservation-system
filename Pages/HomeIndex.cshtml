@page "/HomeIndex"
@model HotelReservationWeb.Pages.HomeIndexModel
@{
    Layout = null;
    ViewData["Title"] = "El Pescador Resort Hotel";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/HomeIndex.css" />
    <link rel="stylesheet" href="/css/UserModal.css" />
</head>
<body>

<div class="page-wrapper">

    <main>

        <header id="heroHeader" class="position-relative">
            <!-- Carousel -->
            <div id="heroCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="4500">
                <div class="carousel-inner">
                    <div class="carousel-item active">
                        <img src="/images/286a661d-6790-4a9a-af29-6e179d27788e.jpg" alt="El Pescador Beach" class="hero-img">
                    </div>
                    <div class="carousel-item">
                        <img src="/images/32a759cc-88c8-4823-94a8-0c64f3bd616a.jpg" alt="Pool Area" class="hero-img">
                    </div>
                    <div class="carousel-item">
                        <img src="/images/520511424_24927818803474124_6850605134008411160_n.jpg" alt="Resort View" class="hero-img">
                    </div>
                </div>
            </div>
            <!-- Overlay content -->
            <div class="hero-overlay">
                <h1 class="display-4 fw-bold animate__animated animate__fadeInDown">Welcome to El Pescador</h1>
                <p class="lead mb-3 animate__animated animate__fadeInUp">Seaside elegance in Bolinao, Pangasinan — your perfect getaway.</p>
                <div class="weather-widget" style="position:absolute;top:20px;right:30px;color:white;opacity:0.95;font-size:1rem;z-index:3;">
                    <span id="weatherContent"><i class="bi bi-cloud-sun"></i> Loading weather...</span>
                </div>
            </div>
        </header>

        <!-- Top navigation (fixed) -->
        <nav id="mainNav" class="navbar navbar-expand-lg">
            <div class="container">
                <a class="navbar-brand" asp-page="/HomeIndex">El Pescador</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div id="navMenu" class="collapse navbar-collapse justify-content-end align-items-center">
                    <ul class="navbar-nav ms-auto align-items-center">
                        <li class="nav-item"><a class="nav-link" href="/HomeIndex#home">Home</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Rooms">Rooms</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Amenities">Amenities</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Venues">Venues</a></li>
                        <li class="nav-item"><a class="nav-link" href="/HomeIndex#discover">Discover</a></li>
                        <li class="nav-item"><a class="nav-link" href="/HomeIndex#about">About</a></li>
                        <li class="nav-item"><a class="nav-link" href="/HomeIndex#contact">Contact</a></li>
                    </ul>

                    <div class="dropdown ms-3" id="profileDropdown">
                        <button class="btn profile-circle"
                                id="profileMenuBtn"
                                type="button">
                            <i class="bi bi-person-fill fs-4"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end elegant-dropdown"
                            aria-labelledby="profileMenuBtn">
                        </ul>
                    </div>
                </div>
            </div>
        </nav>

        <!-- ===== STATS / COUNTERS ===== -->
        <section id="home" class="container py-5">
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="stat-card fade-in floating text-center">
                        <h3 class="counter" data-target="14123">0</h3>
                        <p class="mb-0">Guests</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card fade-in floating text-center">
                        <h3 class="counter" data-target="40">0</h3>
                        <p class="mb-0">Rooms</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card fade-in floating text-center">
                        <h3 class="counter" data-target="5">0</h3>
                        <p class="mb-0">Venues</p>
                    </div>
                </div>
            </div>
        </section>
        
<div class="text-center mt-4">
    <button id="toggleFavoritesBtn" class="btn btn-outline-danger px-4" aria-expanded="false">
        <i class="bi bi-heart-fill me-2"></i> See Your Favorites
    </button>
</div>

        <!-- FAVORITES PANEL -->
<div id="favoritesPanel" style="display:none;" class="container my-4">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0"><i class="bi bi-heart-fill text-danger me-2"></i>My Favorites</h5>
                <div class="d-flex gap-2">
                    <button id="clearFavoritesBtn" class="btn btn-sm btn-outline-danger">Clear All</button>
                    <button id="closeFavoritesBtn" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </div>

            <ul class="nav nav-tabs mb-3" id="favTabs">
                <li class="nav-item">
                    <button class="nav-link active" id="tabRooms" data-tab="Room">
                        <i class="bi bi-door-open me-1"></i> Rooms
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" id="tabVenues" data-tab="Venue">
                        <i class="bi bi-building me-1"></i> Venues
                    </button>
                </li>
            </ul>

            <div id="favoritesEmpty" style="display:none;" class="text-muted text-center py-3">
                No favorites yet.
            </div>
            <div id="favoritesList" class="d-flex flex-wrap gap-3"></div>
        </div>
    </div>
</div>

<template id="favoriteSkeleton">
    <div class="favorites-thumbnail" style="width:90px;">
        <div style="width:80px;height:70px;border-radius:8px;background:#e0e0e0;"></div>
        <div style="height:10px;border-radius:4px;background:#e0e0e0;margin-top:6px;"></div>
    </div>
</template>

<!-- ===== FREQUENTLY BOOKED ROOMS ===== -->
<section id="rooms" class="container py-5">
    <h2 class="text-center fw-bold mb-5 fade-in">
        Frequently Booked Rooms
    </h2>
    <div id="userFacilityGrid" class="row g-4 justify-content-center">
    </div>
</section>

        <!-- See All Rooms Button -->
        <div class="d-block text-center py-4 my-4 clearfix">
            <a asp-page="/Rooms" class="btn btn-outline-dark btn-lg px-4 shadow-sm">See All Rooms</a>
        </div>

        <!-- ===== WHY CHOOSE US ===== -->
        <section class="py-5 text-center bg-white">
            <div class="container">
                <h2 class="fw-bold mb-4 fade-in">Why Choose El Pescador?</h2>
                <div class="row g-4">
                    <div class="col-md-4 fade-in">
                        <i class="bi bi-water text-primary fs-1 mb-3"></i>
                        <h5>Beachfront Access</h5>
                        <p>Wake up to breathtaking sea views every morning.</p>
                    </div>
                    <div class="col-md-4 fade-in">
                        <i class="bi bi-cup-straw text-primary fs-1 mb-3"></i>
                        <h5>World-Class Amenities</h5>
                        <p>Enjoy pools, restaurants, and family-friendly spaces.</p>
                    </div>
                    <div class="col-md-4 fade-in">
                        <i class="bi bi-star text-primary fs-1 mb-3"></i>
                        <h5>Trusted by Tourists</h5>
                        <p>A top choice in Pangasinan for local & international guests.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- ===== DISCOVER ===== -->
        <section id="discover" class="parallax-section text-center">
            <div class="container">
                <h2 class="text-white fw-bold mb-4 fade-in">Discover El Pescador</h2>

                <div class="discover-photo fade-in">
                    <img src="/images/drive-download-20251021T014422Z-1-001/3daf7009-0a84-493c-b6cf-26b185687cc9.jpeg" alt="Discover 1" class="discover-img" data-angle="0" />
                    <div class="photo-caption">🌊 Beach Views</div>
                </div>

                <div class="discover-photo fade-in">
                    <img src="/images/7a071f6e-f24c-492d-bef6-e0b59ba8a1f0.jpg" alt="Discover 2" class="discover-img" data-angle="0" />
                    <div class="photo-caption">🏝 Pool & Lounge</div>
                </div>

                <div class="discover-photo fade-in">
                    <img src="/images/drive-download-20251021T014422Z-1-001/aea41d4e-207c-4978-8b23-fdb0dc7be1f4.jpeg" alt="Discover 3" class="discover-img" data-angle="0" />
                    <div class="photo-caption">🎉 Seaside Events</div>
                </div>

                <div class="mt-4 fade-in">
                    <a class="btn btn-outline-light btn-lg" href="#about">Learn More About Us</a>
                </div>
            </div>
        </section>

        <!-- ===== TESTIMONIALS ===== -->
        <section class="bg-light py-5">
            <div class="container text-center">
                <h2 class="fw-bold mb-5 fade-in">What Our Guests Say</h2>
                <div id="testimonialCarousel" class="carousel slide" data-bs-ride="carousel">
                    <div class="carousel-inner">
                        <div class="carousel-item active">
                            <blockquote class="blockquote">
                                <p class="mb-4">"An unforgettable vacation! The rooms were elegant and the beachfront was stunning."</p>
                                <footer class="blockquote-footer">Maria from Manila ⭐⭐⭐⭐⭐</footer>
                            </blockquote>
                        </div>
                        <div class="carousel-item">
                            <blockquote class="blockquote">
                                <p class="mb-4">"Best resort in Pangasinan! Friendly staff and amazing amenities."</p>
                                <footer class="blockquote-footer">John from Cebu ⭐⭐⭐⭐⭐</footer>
                            </blockquote>
                        </div>
                        <div class="carousel-item">
                            <blockquote class="blockquote">
                                <p class="mb-4">"Perfect for family trips. Kids loved the pool and we loved the view."</p>
                                <footer class="blockquote-footer">The Reyes Family ⭐⭐⭐⭐☆</footer>
                            </blockquote>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ===== ABOUT ===== -->
        <section id="about" class="py-5 bg-light">
            <div class="container">
                <h2 class="text-center fw-bold mb-4 fade-in">About El Pescador</h2>
                <p class="text-center text-muted mb-5 fade-in">
                    El Pescador Resort Hotel has been a top destination in Pangasinan for decades —
                    offering breathtaking views, authentic local hospitality, and a place where
                    families and tourists from all over the world can truly relax.
                </p>

                <div id="aboutCarousel" class="carousel slide mb-5" data-bs-ride="carousel">
                    <div class="carousel-inner rounded shadow-lg">
                        <div class="carousel-item active">
                            <img src="/images/6577f5ba-d556-4ee2-a996-308c503e4d7f.jpg" class="d-block w-100" alt="Resort Beach View" loading="lazy">
                        </div>
                        <div class="carousel-item">
                            <img src="/images/520511424_24927818803474124_6850605134008411160_n.jpg" class="d-block w-100" alt="Swimming Pool" loading="lazy">
                        </div>
                        <div class="carousel-item">
                            <img src="/images/286a661d-6790-4a9a-af29-6e179d27788e.jpg" class="d-block w-100" alt="Garden Area" loading="lazy">
                        </div>
                    </div>
                    <button class="carousel-control-prev" type="button" data-bs-target="#aboutCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon"></span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#aboutCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon"></span>
                    </button>
                </div>

                <div class="ratio ratio-16x9 shadow-lg">
                    <iframe src="https://www.youtube.com/embed/Enpwi46w_7I"
                            title="Explore El Pescador!"
                            allowfullscreen>
                    </iframe>
                </div>
            </div>
        </section>

        <!-- ===== CONTACT ===== -->
        <section id="contact" class="contact text-center">
            <div class="container">
                <h2 class="section-title fade-in">Contact Us</h2>
                <p class="fade-in">Email: info@elpescador.ph | Phone: +63 927 145 0110</p>
                <div class="mt-3 fade-in">
                    <a class="btn btn-outline-secondary me-2" href="https://www.facebook.com/elpescadorhotel" target="_blank">
                        <i class="bi bi-facebook me-1"></i> Facebook
                    </a>
                    <a class="btn btn-outline-secondary"
                       href="https://www.google.com/maps/place/El+Pescador+Resort+Hotel/@@16.3906378,119.8949179,1671m/data=!3m1!1e3!4m9!3m8!1s0x3393cc6e615b979d:0xd2311855fb33ac2f!5m2!4m1!1i2!8m2!3d16.3924637!4d119.8955745!16s%2Fg%2F1hc2nflz5"
                       target="_blank" rel="noopener noreferrer">
                        <i class="bi bi-geo-alt me-1"></i> Get Directions
                    </a>
                </div>
            </div>
        </section>

    </main>

    <!-- USER PROFILE MODAL -->
    <div class="modal fade" id="userProfileModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
            <div class="modal-content border-0 shadow-lg rounded-4">

                <div class="modal-header rounded-top-4">
                    <h5 class="modal-title fw-bold">
                        <i class="bi bi-person-circle me-2"></i> My Account
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-body">
                            <h6 class="fw-bold text-primary mb-3">Profile Information</h6>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <small class="text-muted">Full Name</small>
                                    <div class="fw-semibold" id="profileFullName">—</div>
                                </div>
                                <div class="col-md-6">
                                    <small class="text-muted">Email</small>
                                    <div class="fw-semibold" id="profileEmail">—</div>
                                </div>
                                <div class="col-md-6">
                                    <small class="text-muted">Join Date</small>
                                    <div class="fw-semibold" id="profileJoinDate">—</div>
                                </div>
                                <div class="col-md-6">
                                    <small class="text-muted">Favorites</small>
                                    <div class="fw-semibold d-flex flex-column gap-1 mt-1">
                                        <span id="profileFavoriteRooms" class="profile-value">Favorite Rooms: 0</span>
                                        <span id="profileFavoriteVenues" class="profile-value">Favorite Venues: 0</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <h6 class="fw-bold text-primary mb-3">Bookings History</h6>
                    <div id="activeBookingsList" class="vstack gap-3">
                        <!-- booking cards injected here -->
                    </div>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== FOOTER & STAFF LOGIN (Fixed Position placement inside layout wrapper) ===== -->
    <footer class="text-light">
        <div class="container text-center">
            <a class="btn btn-warning btn-lg shadow-lg mb-4 px-5" asp-page="/Accounts/Admin/StaffLogin">
                <i class="bi bi-person-circle me-2"></i> Staff Login
            </a>
            <p class="mb-0 small">© 2025 El Pescador Resort Hotel — All Rights Reserved</p>
        </div>
    </footer>

</div>

<!-- ===== SCRIPTS ===== -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script src="/js/site.js"></script>
<script src="/js/HomeIndex.js"></script>
<script src="/js/user-facilities.js"></script>

</body>
</html>