@page "/Availability"
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Hotel Availability Calendar";
    Layout = "_TopNavbar";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />
<link rel="stylesheet" href="/css/Availabilty.css" />

<style>
   
</style>

<div class="update-page flex-grow-1 p-3">
    <h2>Manage Facilities Availability</h2>
    <hr />

    <div class="mb-3 d-flex flex-wrap align-items-center justify-content-between">
        <div class="d-flex align-items-center mb-2">
            <!-- Search bar -->
            <input type="text"
                   id="facilitySearch"
                   class="form-control facility-search"
                   placeholder="Search Facility..." />
        </div>

        <!-- Sort button -->
        <button id="sortBtn"
                class="btn btn-ui btn-sort-category ms-2"
                type="button"
                title="Sort by Category">
            <i class="bi bi-arrow-down-up"></i>
            <span class="sort-text">Sort by category</span>
        </button>
    </div>

    <!-- Facility List -->
    <div class="list-group" id="mainFacilityList">
        <!-- JS renders items here -->
    </div>

    <!-- Availability Calendar Modal -->
    <div class="modal fade" id="availabilityModal" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">

                <!-- HEADER (UNCHANGED) -->
                <div class="modal-header">
                    <h5 class="modal-title" id="availabilityModalLabel">
                        Set Availability
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <!-- BODY -->
                <div class="modal-body">

                    <!-- YEAR NAVIGATION (TOP CENTER) -->
                    <div class="d-flex align-items-center justify-content-center mb-3 position-relative">

                        <button class="btn btn-sm btn-outline-secondary position-absolute start-0"
                                id="prevYearBtn">
                            <i class="bi bi-chevron-left"></i>
                        </button>

                        <strong id="availabilityYear" class="fs-5">
                            2025
                        </strong>

                        <button class="btn btn-sm btn-outline-secondary position-absolute end-0"
                                id="nextYearBtn">
                            <i class="bi bi-chevron-right"></i>
                        </button>

                    </div>

                    <!-- MONTH GRID -->
                    <div id="monthsGrid" class="d-flex flex-wrap gap-2 justify-content-center"></div>

                </div>

            </div>
        </div>
    </div>

    <!-- Daily Availability Modal -->
    <div class="modal fade" id="dailyModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-md">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="dailyModalLabel">Set Dates</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">

                    <!-- DAYS GRID -->
                    <div id="daysGrid"></div>

                    <!-- Pencil editor / notes area -->
                    <div class="d-flex justify-content-start align-items-center gap-2 mt-3" id="pencilEditorContainer">
                        <button class="btn btn-outline-primary btn-sm" id="pencilEditorBtn" title="Edit Notes">
                            <i class="bi bi-pencil-square"></i> Edit
                        </button>
                    </div>

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="saveDaysBtn">Save</button>
                </div>
            </div>
        </div>
    </div>


</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/Availability.js"></script>


