@page "/Dashboard"
@model HotelReservationWeb.Pages.Accounts.Admin.StaffDashboardModel
@{
    Layout = "_TopNavbar";
    ViewData["Title"] = "Admin Dashboard";
}

<link rel="stylesheet" href="/css/Dashboard.css" />

<div class="container-fluid mt-4">
    <h3 class="mb-4"><i class="bi bi-speedometer2 me-2"></i>Dashboard Overview</h3>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 p-3 text-center">
                <h6 class="text-muted">Total Bookings</h6>
                <h3 id="totalBookings" class="fw-bold text-primary">Loading...</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0 p-3 text-center">
                <h6 class="text-muted">Pending Bookings</h6>
                <h3 id="pendingCheckins" class="fw-bold text-warning">Loading...</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0 p-3 text-center">
                <h6 class="text-muted">Total Revenue</h6>
                <h3 id="totalRevenue" class="fw-bold text-success">Loading...</h3>
            </div>
        </div>
    </div>

    <div class="chart-container">
        <canvas id="bookingChart" height="100"></canvas>
    </div>

    <div class="mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Recent Activity Log</h5>
        <button class="btn btn-outline-secondary btn-sm px-3" onclick="openActivityModal()">
            <i class="bi bi-list-ul me-1"></i> View All
        </button>
    </div>
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover mb-0" id="activityLogTable">
                <thead class="table-light">
                    <tr>
                        <th>Action</th>
                        <th>Details</th>
                        <th>Performed By</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody id="activityLogBody">
                    <tr>
                        <td colspan="4" class="text-center text-muted py-3">Loading...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="activityModal" tabindex="-1" aria-labelledby="activityModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <div>
                    <h5 class="modal-title fw-semibold" id="activityModalLabel">
                        <i class="bi bi-clock-history me-2"></i>All Activity Logs
                    </h5>
                    <p class="text-muted small mb-0">Complete audit trail of all admin actions</p>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-2" style="max-height: 480px; overflow-y: auto; scrollbar-width: thin; scrollbar-color: #cbd5e1 transparent;">
                <style>
                    #activityModal .modal-body::-webkit-scrollbar {
                        width: 5px;
                    }
                    #activityModal .modal-body::-webkit-scrollbar-track {
                        background: transparent;
                    }
                    #activityModal .modal-body::-webkit-scrollbar-thumb {
                        background-color: #cbd5e1;
                        border-radius: 999px;
                    }
                    #activityModal .modal-body::-webkit-scrollbar-thumb:hover {
                        background-color: #94a3b8;
                    }
                </style>
                <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
                    <button class="btn btn-sm btn-outline-secondary active" id="sortNewest" onclick="sortActivityLogs('newest')">
                        <i class="bi bi-sort-down me-1"></i> Newest First
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" id="sortOldest" onclick="sortActivityLogs('oldest')">
                        <i class="bi bi-sort-up me-1"></i> Oldest First
                    </button>
                    <div class="input-group input-group-sm ms-auto" style="max-width: 240px;">
                        <span class="input-group-text bg-white border-end-0 text-muted">
                            <i class="bi bi-search" style="font-size: 13px;"></i>
                        </span>
                        <input type="text" id="activitySearchInput" class="form-control border-start-0 ps-0"
                            placeholder="Search logs..." oninput="filterActivityLogs(this.value)"
                            style="box-shadow: none;">
                    </div>
                </div>
                <table class="table table-hover">
                    <thead class="table-light sticky-top">
                        <tr>
                            <th>Action</th>
                            <th>Details</th>
                            <th>Performed By</th>
                            <th>Date</th>
                            <th class="text-center" style="width: 60px;"></th>
                        </tr>
                    </thead>
                    <tbody id="allActivityLogBody">
                        <tr>
                            <td colspan="5" class="text-center text-muted py-3">Loading...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="/js/Dashboard.js"></script>