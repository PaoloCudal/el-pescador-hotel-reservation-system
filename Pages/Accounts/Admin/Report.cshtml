@page "/Report"
@model HotelReservationWeb.Pages.Accounts.Admin.ReportModel
@{
    ViewData["Title"] = "Report Monthly, Financial, & Occupancy";
    Layout = "_TopNavbar";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />
<link rel="stylesheet" href="/css/Report.css" />

<div class="report-page flex-grow-1 p-3">

    <h2>📊 Reports Center</h2>
    <hr />

    <div class="report-card">

        <p class="subtitle">Generate Financial, Booking & Occupancy Reports</p>

        <div class="date-row">

            <div>
                <label>From</label>
                <input type="date" id="fromDate" class="form-control report-input">
            </div>

            <div>
                <label>To</label>
                <input type="date" id="toDate" class="form-control report-input">
            </div>

        </div>

        <div class="report-actions">

            <button class="btn btn-gold w-100" onclick="downloadFinancial()">
                <i class="bi bi-cash-stack"></i>
                Financial Report
            </button>

            <button class="btn btn-gold w-100" onclick="downloadBooking()">
                <i class="bi bi-journal-text"></i>
                Booking Report
            </button>

            <button class="btn btn-gold w-100" onclick="downloadOccupancy()">
                <i class="bi bi-building"></i>
                Occupancy Report
            </button>

        </div>

        <div id="loadingSpinner" class="d-none text-center mt-3">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Generating PDF...</span>
            </div>
            <p class="mt-2 text-muted small">Generating PDF, please wait...</p>
        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/Report.js"></script>